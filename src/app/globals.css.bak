@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --bg-primary: #193126;
    --text-primary: #f2dac4;
  }

  body {
    @apply bg-brand-dark-green text-brand-sand font-sans antialiased overflow-x-hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    @apply font-sans font-bold leading-tight mb-4 text-brand-peach;
  }
}

@layer components {
  .container-custom {
    @apply w-full max-w-[1200px] mx-auto px-6;
  }
  
  .btn-primary {
    @apply inline-flex items-center justify-center px-10 py-3 rounded-full font-bold cursor-pointer transition-all duration-300 bg-gradient-to-r from-[#f2dac4] to-[#e8c4a4] text-[#593c28] shadow-[0_4px_12px_rgba(0,0,0,0.3)] hover:shadow-[0_6px_16px_rgba(0,0,0,0.4)] hover:-translate-y-[2px] border-none font-sans;
  }

  .btn-secondary {
    @apply inline-flex items-center justify-center px-10 py-3 rounded-full font-bold cursor-pointer transition-all duration-300 bg-transparent text-brand-peach border-2 border-brand-peach shadow-[0_4px_12px_rgba(0,0,0,0.1)] hover:bg-brand-peach/10 hover:-translate-y-[2px] font-sans;
  }
}
